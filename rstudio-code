library(tidyverse)
library(scales)

# CSV'yi oku
df <- read_delim("belediye_atiklari.csv",
                 delim = ";",
                 locale = locale(decimal_mark = ",", encoding = "latin1"))

# SC<tun adlarD1nD1 kD1salt
df <- df %>%
  rename(
    bolge    = bolgeler,
    il       = il,
    ilce     = ilce,
    biyometan = biyometanizasyona_uygun_belediye_atiklarim_miktari_ton_yil,
    yakma     = yakmaya_uygun_belediye_atiklari_miktari_ton_yil,
    bio_enerji   = biyometanizasyona_uygun_belediye_atiklari_enerji_esdegeri_tep_yil,
    yakma_enerji = yakmaya_uygun_belediye_tiklari_enerji_esdegeri_tep_yil
  )

# SayD1sal dC6nC<EC<m ve bC6lge bazD1nda toplam
bolge_df <- df %>%
  mutate(
    biyometan    = as.numeric(biyometan),
    yakma        = as.numeric(yakma)
  ) %>%
  group_by(bolge) %>%
  summarise(
    Biyometanizasyon = sum(biyometan, na.rm = TRUE),
    Yakma            = sum(yakma,     na.rm = TRUE),
    .groups = "drop"
  ) %>%
  pivot_longer(cols = c(Biyometanizasyon, Yakma),
               names_to  = "tur",
               values_to = "miktar")

# BC6lge sD1ralamasD1 (toplama gC6re bC<yC<kten kC<C'C<De)
bolge_sirali <- bolge_df %>%
  group_by(bolge) %>%
  summarise(toplam = sum(miktar)) %>%
  arrange(desc(toplam)) %>%
  pull(bolge)

bolge_df$bolge <- factor(bolge_df$bolge, levels = bolge_sirali)

# Grafik
ggplot(bolge_df, aes(x = bolge, y = miktar / 1e6, fill = tur)) +
  geom_col(position = "dodge", width = 0.65) +
  scale_fill_manual(
    values = c("Biyometanizasyon" = "#3266ad", "Yakma" = "#85B7EB"),
    name   = NULL
  ) +
  scale_y_continuous(
    labels = label_number(suffix = " M ton", accuracy = 0.1),
    expand = expansion(mult = c(0, 0.05))
  ) +
  scale_x_discrete(labels = function(x) str_wrap(x, width = 12)) +
  labs(
    title    = "Bolgelere gore belediye atik potansiyeli",
    subtitle = "Biyometanizasyon ve yakma yontemine uygun atik miktarlari (ton/yil)",
    x        = NULL,
    y        = "Atik miktari (milyon ton/yD1l)",
    caption  = "Kaynak: belediye_atiklari.csv"
  ) +
  theme_minimal(base_size = 13) +
  theme(
    plot.title       = element_text(face = "bold", size = 15),
    plot.subtitle    = element_text(color = "gray40", margin = margin(b = 12)),
    axis.text.x      = element_text(angle = 20, hjust = 1),
    legend.position  = "top",
    legend.key.size  = unit(0.5, "cm"),
    panel.grid.major.x = element_blank(),
    panel.grid.minor   = element_blank()
  )

