library(tidyverse)
library(ggplot2)
library(scales)

# ------------------------------------------------------------
# 1. VERİ OKUMA
# encoding = "latin1" Türkçe CSV için gerekli
# ------------------------------------------------------------
belediye <- read.csv("belediye_atiklari.csv", sep = ";", encoding = "latin1")
ormansal <- read.csv("ormansal_atiklar.csv",  sep = ";", encoding = "latin1")

# ------------------------------------------------------------
# 2. VERİ TEMİZLEME VE TOPLAM HESAPLAMA
# ------------------------------------------------------------

# -- BELEDİYE --
belediye <- belediye %>%
  mutate(
    biyometan_ton = as.numeric(gsub(",", ".", biyometanizasyona_uygun_belediye_atiklarim_miktari_ton_yil)),
    yakma_ton     = as.numeric(gsub(",", ".", yakmaya_uygun_belediye_atiklari_miktari_ton_yil))
  )

bel_bio <- sum(belediye$biyometan_ton, na.rm = TRUE)
bel_yak <- sum(belediye$yakma_ton,     na.rm = TRUE)

# -- ORMANSAL --
# Endüstriyel olarak değerlendirilmeyenler → yakmaya uygun
# Suçeyrat (ince dal, yaprak vb.)           → biyometanizasyona uygun
# 1 ster ≈ 0.7 ton

STER_TON <- 0.7

ormansal <- ormansal %>%
  rename_with(str_trim) %>%
  mutate(
    endustriyel_ton = as.numeric(gsub(",", ".", endustriyel_olarak_degerlendirilmeyenler_ster_yil_)) * STER_TON,
    suceyrattan_ton = as.numeric(gsub(",", ".", suceyrattan_elde_edilebilecekler_ster_yil))           * STER_TON
  )

orm_bio <- sum(ormansal$suceyrattan_ton,  na.rm = TRUE)
orm_yak <- sum(ormansal$endustriyel_ton,  na.rm = TRUE)

# ------------------------------------------------------------
# 3. YÜZDE HESAPLA VE VERİ ÇERÇEVESİ OLUŞTUR
# ------------------------------------------------------------
ozet <- tibble(
  Kaynak           = c("Belediye Atıkları", "Ormansal Atıklar"),
  Biyometanizasyon = c(bel_bio, orm_bio),
  Yakma            = c(bel_yak, orm_yak)
) %>%
  mutate(
    Toplam  = Biyometanizasyon + Yakma,
    Pct_Bio = round(Biyometanizasyon / Toplam * 100),
    Pct_Yak = round(Yakma            / Toplam * 100)
  )

# Uzun formata çevir
ozet_long <- ozet %>%
  select(Kaynak, `Biyometanizasyona Uygun` = Pct_Bio, `Yakmaya Uygun` = Pct_Yak) %>%
  pivot_longer(
    cols      = c("Biyometanizasyona Uygun", "Yakmaya Uygun"),
    names_to  = "Islem_Turu",
    values_to = "Yuzde"
  ) %>%
  mutate(
    Islem_Turu = factor(Islem_Turu, levels = c("Yakmaya Uygun", "Biyometanizasyona Uygun"))
  )

# ------------------------------------------------------------
# 4. EKSENLERDEKİ ETİKETLER - Parantez İçinde Alt Kategoriler
# ------------------------------------------------------------
# X ekseninde her kaynağın ne tür atıkları kapsadığını belirt
# \n ile alt satıra geçiyoruz, parantez içinde alt kategoriler

eksen_etiketleri <- c(
  "Belediye Atıkları" =
    "Belediye Atıkları\n(Mutfak, bahce, plastik, kagıt, cam, metal, tekstil, vb.)",
  
  "Ormansal Atıklar" =
    "Ormansal Atıklar\n(Odun, tomruk artığı, budama dalı, suceyrat, kabuk, vb.)"
)

ozet_long <- ozet_long %>%
  mutate(
    Kaynak = factor(
      Kaynak,
      levels = c("Belediye Atıkları", "Ormansal Atıklar"),
      labels = eksen_etiketleri
    )
  )

# ------------------------------------------------------------
# 5. YÜZDELİ YIĞILMIş SÜTUN GRAFİK - MAVİ TONLARI
# ------------------------------------------------------------
renk_paleti <- c(
  "Yakmaya Uygun"           = "#B5D4F4",  # açık mavi
  "Biyometanizasyona Uygun" = "#378ADD"   # koyu mavi
)

p <- ggplot(ozet_long, aes(x = Kaynak, y = Yuzde, fill = Islem_Turu)) +
  geom_bar(
    stat      = "identity",
    position  = "stack",
    width     = 0.45,
    color     = "white",
    linewidth = 0.5
  ) +
  geom_text(
    aes(
      label = paste0("%", Yuzde),
      color = Islem_Turu
    ),
    position = position_stack(vjust = 0.5),
    size     = 5,
    fontface = "bold",
    show.legend = FALSE
  ) +
  scale_color_manual(
    values = c(
      "Biyometanizasyona Uygun" = "white",
      "Yakmaya Uygun"           = "#185FA5"
    )
  ) +
  scale_fill_manual(values = renk_paleti) +
  scale_y_continuous(
    labels = function(x) paste0("%", x),
    breaks = seq(0, 100, 25),
    limits = c(0, 100),
    expand = expansion(mult = c(0, 0.02))
  ) +
  labs(
    title    = "Atık Kaynağına Gore İsleme Uygunluğu",
    subtitle = "Yakmaya Uygun ve Biyometanizasyona Uygun Atıkların Yuzdesel Dağılımı\n(Hayvansal atıklar haric — 81 ilde %100 biyometanizasyona uygundur)",
    x        = NULL,
    y        = "Oran (%)",
    fill     = "İşleme Yontemi",
    caption  = "Kaynak: Belediye ve Ormansal Atık Veri Setleri\n* Ormansal atıklar ster → ton donusumu: 1 ster = 0.7 ton"
  ) +
  theme_minimal(base_size = 13) +
  theme(
    plot.title         = element_text(face = "bold", size = 15, hjust = 0.5),
    plot.subtitle      = element_text(size = 10, hjust = 0.5, color = "gray40"),
    plot.caption       = element_text(size = 8.5, color = "gray50", hjust = 1),
    legend.position    = "top",
    legend.title       = element_text(face = "bold", size = 11),
    legend.text        = element_text(size = 11),
    axis.text.x        = element_text(size = 11, lineheight = 1.3),
    axis.text.y        = element_text(size = 10),
    panel.grid.major.x = element_blank(),
    panel.grid.minor   = element_blank()
  )

print(p)

